# Server
PORT=3000
HOST=127.0.0.1

# OCI auth method: config, instance_principal, or resource_principal.
OCI_AUTH_METHOD=config

# Config-file auth. Uses your local OCI CLI config by default.
OCI_CONFIG_FILE=~/.oci/config
OCI_PROFILE=DEFAULT

# Optional for config-file auth because the tenancy is inferred from the OCI profile.
# Required for principal-based auth if the provider cannot expose a tenancy OCID.
OCI_TENANCY_OCID=ocid1.tenancy.oc1..exampleuniqueid

# Optional root for limits queries. Defaults to the tenancy OCID.
OCI_LIMITS_COMPARTMENT_OCID=

# Optional subscription OCID when a service exposes subscription-specific limits.
OCI_SUBSCRIPTION_OCID=

# Optional control region used to read tenancy region subscriptions.
# Defaults to OCI_REGION from the auth provider when available, then us-ashburn-1.
OCI_IDENTITY_REGION=

# Optional dashboard/API defaults.
DEFAULT_REGION_NAMES=
DEFAULT_SERVICE_NAMES=
DEFAULT_LIMIT_NAMES=
DEFAULT_LIMIT_FILTER=
INCLUDE_NON_READY_REGIONS=false

# Scan controls. Raise carefully; this app can create many OCI API calls.
REGION_CONCURRENCY=3
SERVICE_CONCURRENCY=6
RESOURCE_AVAILABILITY_CONCURRENCY=2
OCI_PAGE_SIZE=1000
CACHE_TTL_SECONDS=300
